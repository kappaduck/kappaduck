# Auto detect text files and perform LF normalization

*           text=auto

# .Net files

*.cs        text diff=csharp
*.slnx      text eol=crlf
*.csproj    text eol=crlf

# Documents

*.md        text diff=markdown linguist-detectable

# Github files

codeowners  text

# Graphics

*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary

# Serialisation

*.json      text
*.xml       text
*.yaml      text eol=lf
*.yml       text eol=lf

# Web files

*.html     text diff=html

# Web style files

*.css      text diff=css

# Web script files

*.js       text diff=javascript
*.ts       text diff=typescript

# Exclude files form exporting

.gitattributes export-ignore
.gitignore     export-ignore
