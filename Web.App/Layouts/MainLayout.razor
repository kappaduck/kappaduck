@using System.Runtime.InteropServices.JavaScript
@using Web.App.Options

@inherits LayoutComponentBase
@inject ProjectOptions project

<header>
	<a class="nav-logo" href="/">
		<svg width="32" height="32" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
			<circle cx="50" cy="50" r="47" fill="#085041" stroke="#5DCAA5" stroke-width="5" />
			<rect x="20" y="46" width="46" height="32" rx="14" fill="#9FE1CB" />
			<rect x="32" y="22" width="38" height="32" rx="12" fill="#5DCAA5" />
			<rect x="64" y="30" width="20" height="10" rx="5" fill="#AFA9EC" />
			<circle cx="56" cy="32" r="5.5" fill="#0a0a0f" />
			<circle cx="57.8" cy="30.2" r="2" fill="white" />
			<rect x="32" y="60" width="18" height="10" rx="5" fill="#1D9E75" />
		</svg>
		<span class="nav-title">
			<span class="kappa">Kappa</span><span class="duck">Duck</span>
		</span>
	</a>
	<nav>
		<div class="nav-links">
			<a href="@project.Url" target="_blank" class="github-link">
				<i class="@Icons.Github"></i>
				<span>GitHub</span>
			</a>
		</div>
		<button @onclick="ToggleTheme" class="theme-btn" title="Toggle light/dark theme" aria-label="Toggle light/dark theme">
			<i class="@Icons.Moon icon-moon"></i>
			<i class="@Icons.Sun icon-sun"></i>
		</button>
	</nav>
</header>
@Body
<footer>
	<span class="copy">&copy; @DateTime.Now.Year <strong>KappaDuck</strong>. All rights reserved.</span>
	<span class="right">Build with Blazor &middot; @project.Version</span>
</footer>
